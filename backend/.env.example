# LLM 服务 — 必填
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 调用控制
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=8192

# 测试数据集输入侧限制（F-LM-03，与前端校验对齐；后端二次兜底）
DATATEST_MAX_ROWS=1000
DATATEST_MAX_PROMPT_LEN=2000
DATATEST_MAX_FIELDS=50

# SQL 血缘分析输入侧限制（与前端校验对齐；后端二次兜底）
LINEAGE_SQL_MAX_CHARS=50000

# Neo4j 推送（F-EX-07；留空则禁用直接推送）
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# CORS 允许来源（生产部署填前端域名，逗号分隔；留空则用本地开发地址 5173）
CORS_ORIGINS=

# BI 报表上传文件大小上限（MB，默认 10）
BI_MAX_UPLOAD_MB=10

